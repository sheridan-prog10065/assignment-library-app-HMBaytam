<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryAdminPage"
             Title="Manage Book Assets">
    <Grid RowDefinitions="Auto, Auto, *"
          Margin="20,0"
          RowSpacing="10">
        <VerticalStackLayout Spacing="10">
            <Label Text="New Book" FontSize="24"
                   Margin="0, 20, 0, 0"/>
            <Label Text="Book Type:" FontSize="14"/>
            <Picker x:Name="_pickerBookType" Title="{OnPlatform MacCatalyst='', Default='Book Type'}">
                <Picker.Items>
                    <x:String>Paper</x:String>
                    <x:String>Digital</x:String>
                    <x:String>Audio</x:String>
                </Picker.Items>
            </Picker>
            <Label Text="Name:" FontSize="14"/>
            <Entry x:Name="_entryName" Placeholder="Enter the name of the book." FontSize="17"/>
            <Label Text="ISBN" FontSize="14"/>
            <Entry x:Name="_entryISBN" Placeholder="Enter Book ISBN" FontSize="17"/>
            <Label Text="Authors" FontSize="14"/>
            <Entry x:Name="_entryAuthors" Placeholder="Enter the list of authors" FontSize="17"/>
            <Grid ColumnDefinitions="*, Auto"
                  Margin="0, 10"
                  ColumnSpacing="10">
                <Button Text="Register Book"
                        Grid.Column="0" WidthRequest="250"
                        HorizontalOptions="Start"
                        Clicked="OnRegisterBook"/>
            </Grid>

        </VerticalStackLayout>
        <Label Text="Book Inventory" FontSize="24"
               Grid.Row="1"/>
        <Border Grid.Row="2"
                Margin="{OnPlatform Default='0, 0, 0, 80',
                                    iOS='0, 0, 0, 30',
                                    Android='0, 0, 0, 10'}">
            <CollectionView x:Name="_lstBooks" HorizontalOptions="Fill" />
        </Border>

    </Grid>
</ContentPage>
